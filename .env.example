# Database
# For `docker compose up`, the app container injects this automatically and
# overrides whatever's below. Keep this set for `npm run dev` against a local
# Postgres.
DATABASE_URL=postgres://user:pass@localhost:5432/acropolisos

# Auth
AUTH_SECRET=

# LLM (BYOK)
LLM_PROVIDER=anthropic
LLM_API_KEY=

# Inngest
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# US-028: Side effects channels
# Email transport: when RESEND_API_KEY is set, notify_member / notify_steward
# go via Resend; otherwise they log only. Per-action overrides live in YAML
# (action_types.<name>.side_effects_config).
RESEND_API_KEY=
SIDE_EFFECT_MAIL_FROM=noreply@acropolisos.local
STEWARD_EMAILS=
SIDE_EFFECT_WEBHOOK_URL=

# n8n integration (F2-step2b)
# Set up the n8n owner account at http://localhost:5678, then generate an API
# key at Settings → API. The app container reaches n8n via internal Docker DNS.
N8N_BASE_URL=http://n8n:5678
N8N_API_KEY=SET_ME_VIA_N8N_UI

# ── Communication channels (inbound) ────────────────────────────────────────
# Each channel verifies the request, then deposits messages into raw_inbox
# (source=<channel>) as data — no authenticated reads/actions. Endpoints are
# INERT (HTTP 503) until the matching secret below is set. Put real values in
# .env (gitignored); NEVER commit them. The app reads .env via env_file, so after
# editing .env recreate the app to load it: docker compose up -d --no-deps app

# Telegram — inbound webhook at /api/channels/telegram
#  1) @BotFather → /newbot → gives you a BOT TOKEN (used only to register the
#     webhook below; the app itself never reads the token).
#  2) Set TELEGRAM_WEBHOOK_SECRET to any random string (e.g. openssl rand -hex 32);
#     Telegram echoes it in the X-Telegram-Bot-Api-Secret-Token header and the
#     route constant-time-compares it.
#  3) Register (run once, with your bot token — keep the token out of git):
#     curl "https://api.telegram.org/bot<BOT_TOKEN>/setWebhook" \
#       --data-urlencode url=https://acropolisos.castalia.one/api/channels/telegram \
#       --data-urlencode secret_token="$TELEGRAM_WEBHOOK_SECRET"
TELEGRAM_WEBHOOK_SECRET=

# Discord — slash-command Interactions Endpoint at /api/channels/discord
#  discord.com/developers → your app → General Information → PUBLIC KEY (64-char
#  hex; not secret, but treat it as config). The route Ed25519-verifies every
#  interaction against it. After deploy, set the app's "Interactions Endpoint URL"
#  to the route above (Discord sends a signed PING that must get {type:1}), then
#  register your slash command with the bot token (see the build report runbook).
DISCORD_PUBLIC_KEY=
#  Discord Gateway worker (workers/discord-gateway) — the bot token for the
#  always-on inbound Gateway connection (Guilds + GuildMessages + MessageContent
#  intents). SECRET: keep it ONLY in gitignored .env, NEVER commit a real value.
#  When unset, the worker is inert ("Discord Gateway idle (no token)"). Reset the
#  token + enable the MESSAGE_CONTENT intent in the Developer Portal before use.
DISCORD_BOT_TOKEN=
